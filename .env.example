# ─── Clerk (auth — identity and magic links only; Organizations NOT used) ───
# https://dashboard.clerk.com → Keys
CLERK_SECRET_KEY=
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=

# Clerk auth flow URLs
# https://clerk.com/docs/deployments/clerk-environment-variables
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_SIGN_IN_FORCE_REDIRECT_URL=/dashboard
NEXT_PUBLIC_CLERK_SIGN_UP_FORCE_REDIRECT_URL=/onboarding

# ─── Supabase (database + storage) ──────────────────────────────────────────
# Project settings → API in the Supabase dashboard.
# Service role bypasses RLS — only import in lib/supabase/admin.ts.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ─── Anthropic (Claude Sonnet for SOP conversion + glossary flagging) ───────
# https://console.anthropic.com/settings/keys
# Haiku is reserved for Phase 2 high-frequency tasks.
ANTHROPIC_API_KEY=

# ─── Google Cloud Translation (translation with glossary injection) ─────────
# Cloud Console → APIs & Services → Credentials.
# Never use Claude for translation.
GOOGLE_CLOUD_TRANSLATION_API_KEY=

# ─── App ────────────────────────────────────────────────────────────────────
# Public base URL used to construct QR code URLs and post-auth redirects.
# Dev: http://localhost:3000
# Preview/prod: your Vercel domain
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─── Monitor pairing cookie signer ──────────────────────────────────────────
# Any 32+ character random string. Rotating invalidates all paired monitors.
# Generate: `openssl rand -base64 48`
MONITOR_COOKIE_SECRET=

# ─── Super-admin impersonation cookie signer ────────────────────────────────
# Any 32+ character random string. Rotating invalidates every active
# impersonation session (super admins have to click Impersonate again).
# Generate: `openssl rand -base64 48`
IMPERSONATION_COOKIE_SECRET=
